# SantaCruzOVR production — copy to deploy/prod/.env on the VPS (gitignored).
# Postgres + Redis are MANAGED/EXTERNAL.

OVR_DATABASE_URL=postgresql://app_user:pass@managed-pg-host:5432/stcz_eovr?sslmode=require
OVR_REDIS_URL=rediss://default:pass@managed-redis-host:6379
OVR_SESSION_SECRET=replace-with-long-random-string

API_REPLICAS=2
WEB_REPLICAS=2
