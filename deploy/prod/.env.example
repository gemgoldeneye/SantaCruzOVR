# SantaCruzOVR production — copy to deploy/prod/.env on the VPS (gitignored).
# Self-hosted Postgres+PgBouncer (deploy/prod/db-provision.sh) and host Redis
# (deploy/prod/redis-provision.sh). The real values are generated by those
# scripts; paste them into the Jenkins credentials, not here.
#
# IMPORTANT: this app runs `prisma migrate deploy` (db:deploy) using this single
# DATABASE_URL, which needs DDL rights — so use the OWNER role URL, not the app
# role. db-provision.sh prints OWNER_DATABASE_URL in /root/zambal-db-stcz_eovr.env.

# OWNER role on the SEPARATE DB server (its IP/host), through PgBouncer (:6432).
# Run db-provision.sh with DB=stcz_eovr — own DB, isolated from the original OVR
# `eovr` database. <db-host> is the DB server's address reachable from the app box.
OVR_DATABASE_URL=postgres://stcz_eovr_owner:<generated-pw>@<db-host>:6432/stcz_eovr?sslmode=require
# Redis is host-installed on the APP box (not the DB box), reached via
# host.docker.internal. Use a free DB index (suite uses 0/1/2; this prod app uses /3).
OVR_REDIS_URL=redis://host.docker.internal:6379/3
OVR_SESSION_SECRET=replace-with-long-random-string

API_REPLICAS=2
WEB_REPLICAS=2
