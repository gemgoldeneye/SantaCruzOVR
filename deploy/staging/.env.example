# SantaCruzOVR STAGING — copy to deploy/staging/.env on the staging VPS (gitignored).
# Use a SEPARATE managed Postgres + Redis from prod.

OVR_DATABASE_URL=postgresql://app_user:pass@staging-pg-host:5432/stcz_eovr?sslmode=require
OVR_REDIS_URL=rediss://default:pass@staging-redis-host:6379
OVR_SESSION_SECRET=replace-with-long-random-string-staging

# 1 replica is plenty for staging.
API_REPLICAS=1
WEB_REPLICAS=1
