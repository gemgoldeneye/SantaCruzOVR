# SantaCruzOVR STAGING — copy to deploy/staging/.env on the staging VPS (gitignored).
# Self-hosted Postgres+PgBouncer (deploy/prod/db-provision.sh) and host Redis
# (deploy/prod/redis-provision.sh). The real values are generated by those
# scripts; paste them into the Jenkins credentials, not here. Use a SEPARATE DB
# (or DB index) from prod so staging never touches production data.
#
# IMPORTANT: this app runs `prisma migrate deploy` (db:deploy) using this single
# DATABASE_URL, which needs DDL rights — so use the OWNER role URL, not the app
# role. db-provision.sh prints OWNER_DATABASE_URL in /root/zambal-db-<DB>.env.

# OWNER role on the SEPARATE DB server, through PgBouncer (:6432). Provision with
# DB=stcz_eovr_staging — isolated from prod and from the original OVR database.
OVR_DATABASE_URL=postgres://stcz_eovr_staging_owner:<generated-pw>@<db-host>:6432/stcz_eovr_staging?sslmode=require
# Redis is host-installed on the APP box, via host.docker.internal. Staging uses
# its own DB index (/4) so it can't collide with prod (/3) on the shared instance.
OVR_REDIS_URL=redis://host.docker.internal:6379/4
OVR_SESSION_SECRET=replace-with-long-random-string-staging

API_REPLICAS=1
WEB_REPLICAS=1
