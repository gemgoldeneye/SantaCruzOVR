# e-OVR environment. Copy to `.env` and adjust. `.env*` is gitignored.
#
# ⛔️ LOCAL DEVELOPMENT ONLY — these defaults (and the docker-compose stack that
# uses them) are a DEMO SANDBOX. DO NOT deploy to production or expose publicly.
# Hardcoded credentials, a placeholder SESSION_SECRET, and plain HTTP (no TLS)
# are intentional for local convenience and are UNSAFE for real data/money.
# Production needs managed data stores, rotated/secret-managed credentials, TLS
# (COOKIE_SECURE=true), real auth, and a real payment gateway. See README.md and
# the strict warning at the top of docker-compose.yml.

# Postgres connection (used by the app + the migrate/seed step). Inside docker
# compose the host is `db`; for host dev against compose infra, use localhost.
DATABASE_URL=postgresql://eovr:eovr@localhost:5432/eovr

# Redis connection (admin sessions + login rate-limiting). In compose: `redis`.
REDIS_URL=redis://localhost:6379

# Selects the real Postgres backend + real admin auth. A non-empty DATABASE_URL
# also enables it; set this explicitly for clarity.
EOVR_DATA_BACKEND=prisma

# Reserved for session hardening/signing. Use a long random value in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Superadmin account seeded into Postgres by `db:seed` (DB mode). Set these to
# your OWN values before seeding a real deployment — they give the SUPER_ADMIN
# its own credentials instead of the shared demo password. If unset, the seed
# falls back to username `superadmin` and the demo password (LOCAL-DEV-ONLY).
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-to-a-strong-password

# Force the `Secure` flag on auth cookies. Leave unset for HTTP deployments
# (e.g. http://localhost) — a Secure cookie is dropped over plain HTTP and logs
# users out on full-page navigations. When served behind an HTTPS proxy the
# `x-forwarded-proto: https` header already enables Secure automatically; set
# this to `true` only to force it on.
# COOKIE_SECURE=true

# Mock fallback only: when DATABASE_URL/EOVR_DATA_BACKEND are unset, the app uses
# the file-backed mock store at this path (default: OS temp dir).
# EOVR_STORE_FILE=/tmp/eovr-store.json
